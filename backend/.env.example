# OpenAI-compatible API settings
# Supports OpenAI, Groq, Ollama, or any OpenAI-compatible endpoint
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Media API keys (free tiers available)
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-api-key
# Giphy: https://developers.giphy.com/
GIPHY_API_KEY=your-giphy-api-key
# Unsplash: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# Freesound: https://freesound.org/apiv2/apply
FREESOUND_API_KEY=your-freesound-api-key

# AI Generation Fallback Settings
AI_IMAGE_ENABLED=true
AI_VIDEO_ENABLED=false
AI_IMAGE_MAX_PER_VIDEO=5
AI_VIDEO_MAX_PER_VIDEO=3
AI_IMAGE_QUALITY=standard
AI_IMAGE_SIZE=1792x1024
REPLICATE_API_TOKEN=your-replicate-token

# Media caching
MEDIA_CACHE_ENABLED=true

# Output directory for generated files
OUTPUT_DIR=./output

# TTS voice (Microsoft Edge TTS voices)
# Options: en-US-AriaNeural, en-US-GuyNeural, en-US-JennyNeural, etc.
TTS_VOICE=en-US-AriaNeural

# Server configuration
HOST=0.0.0.0
PORT=8000
